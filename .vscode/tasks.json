{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Astro Dev Server",
			"type": "shell",
			"command": "npm",
			"args": ["run", "dev"],
			"isBackground": true,
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".*",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".*Local.*",
						"endsPattern": ".*Local.*"
					}
				}
			],
			"group": "none"
		}
	]
}
