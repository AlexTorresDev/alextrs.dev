{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "@/components/*": [
        "./src/components/*"
      ],
      "@/pages/*": [
        "./src/pages/*"
      ],
      "@/styles/*": [
        "./src/styles/*"
      ],
      "@/layouts/*": [
        "./src/layouts/*"
      ],
      "@/public/*": [
        "./src/public/*"
      ],
      "@/data/*": [
        "./src/data/*"
      ]
    }
  }
}