---
import Social from '@/components/Social.astro'

import { getLangFromUrl, useTranslations } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<footer class="bg-white rounded-lg shadow m-4 dark:bg-neutral-800">
	<div
		class="w-full mx-auto max-w-screen-xl p-4 flex flex-col md:flex-row gap-5 md:gap-0 items-center md:justify-between"
	>
		<span class="text-sm text-neutral-500 sm:text-center dark:text-neutral-400">
			{t('footer.copyright-1')}
			<span class="font-bold">Alex Torres</span>
			{t('footer.copyright-2')}
		</span>
		<Social inFooter />
	</div>
</footer>
