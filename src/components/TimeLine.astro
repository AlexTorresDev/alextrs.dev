---
import { Briefcase, GraduationCap, Laptop, LaptopMinimal, Users } from '@lucide/astro'

type Props = {
	title: string
	date?: string
	subtitle: string
	modality?: string
	side?: 'left' | 'right'
}

const { title, date, subtitle, modality, side = 'right' }: Props = Astro.props

const lowerTitle = title.toLowerCase()
const Icon = lowerTitle.includes('ingeniero') ||
	lowerTitle.includes('tecnologo') ||
	lowerTitle.includes('tecnólogo')
	? GraduationCap
	: lowerTitle.includes('desarrollador')
		? Laptop
		: Briefcase

const lowerModality = modality ? modality.toLowerCase() : ''
const ModalityIcon = lowerModality.includes('remoto')
	? LaptopMinimal
	: lowerModality.includes('hibrido') || lowerModality.includes('híbrido')
		? Users
		: null

const MarkerIcon = ModalityIcon || Icon
---

<li
	class:list={[
		'relative mb-10 md:w-1/2',
		side === 'left'
			? 'md:mr-auto md:pr-10'
			: 'md:ml-auto md:pl-10'
	]}
>
	<div
		class:list={[
			'relative flex gap-2 pl-11 md:pl-0',
			side === 'left'
				? 'md:justify-end md:pr-6 md:-mr-10'
				: 'md:justify-start md:-ml-13'
		]}
	>
		<time
			class:list={[
				'text-sm text-slate-500 dark:text-slate-400 order-2 md:order-2',
				side === 'left' ? 'md:order-1 md:text-right md:pr-5' : 'md:order-2 md:pl-5'
			]}
		>
			{date && <span class="block">{date}</span>}
			{subtitle}
		</time>
		<span
			class:list={[
				'order-1 md:order-1 inline-flex h-7 w-7 items-center justify-center rounded-full bg-emerald-500 text-white border border-emerald-400/40 -ml-10.5 md:ml-0',
				side === 'left' ? 'md:order-2 md:-mr-10' : 'md:order-1 md:-ml-10'
			]}
			title={modality || title}
		>
			<MarkerIcon class="h-3.5 w-3.5" />
		</span>
	</div>

	<div class="mt-2 rounded-2xl bg-[linear-gradient(140deg,rgba(16,185,129,0.35),rgba(56,189,248,0.25))] ml-9 md:ml-0">
		<div class="rounded-2xl bg-white/70 p-6 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:bg-white/10">
			<h3 class="mb-1 text-lg font-semibold text-neutral-800 dark:text-white">
				{title}
			</h3>
			<div class="text-sm font-normal leading-relaxed text-neutral-600 dark:text-neutral-300 space-y-3">
				<slot />
			</div>
		</div>
	</div>
</li>
