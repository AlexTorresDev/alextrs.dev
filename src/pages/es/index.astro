---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Card from '@/components/Card.astro'
import Social from '@/components/Social.astro'

import projects from '@/data/projects'
import { getLangFromUrl } from '@/i18n/utils'

const lang = getLangFromUrl(Astro.url)
---

<BaseLayout>
	<div class="pb-12 mt-5">
		<div class="mt-12">
			<span class="block mb-1 text-xl py-1 dark:text-white/70">Hola 👋</span>
			<h1
				class="mb-4 text-4xl font-extrabold leading-none tracking-tight text-neutral-800 md:text-5xl lg:text-6xl dark:text-white"
			>
				Soy Alex
			</h1>
			<span
				class="block mb-1 text-3xl py-3 font-bold text-emerald-600 contrast-200"
			>
				Desarrollador e ingeniero de telemática
			</span>
		</div>

		<p
			class="py-2 text-lg font-normal text-neutral-600 lg:text-xl dark:text-neutral-400"
		>
			Más de 6 años de experiencia en desarrollo de aplicaciones móviles y web.
			Me enfrenté a un reto de realizar un cambio de JSF a Angular, React y
			SprintBoot para proyectos nuevos. Además desarrollé una aplicación móvil
			para una empresa americana para el manejo de su flota y geolocalización.
			Hice una plataforma móvil y web para la alcaldía municipal de Sopó, y he
			aportado a proyectos de reconocidos bancos.
		</p>
		<div class="mt-8">
			<Social />
		</div>
	</div>

	<div class="mb-12">
		<h2 class="text-3xl font-bold dark:text-white mb-5 mt-28">🎊 Proyectos</h2>

		<div class="flex flex-col gap-8">
			{
				projects.map((project) => (
					<Card
						title={project.name}
						img={project.image}
						desc={project.description[lang]}
						url={project.repo}
						badge={project.status}
						tags={[...project.tags, ...project.languages]}
					/>
				))
			}
		</div>
	</div>
</BaseLayout>
