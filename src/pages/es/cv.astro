---
import TimeLineElement from '@/components/TimeLine.astro'
import { skills } from '@/data/skills'
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title="Hoja de Vida">
	<section>
		<h1 class="text-3xl font-bold dark:text-white mb-5">
			🎉 Hoja de vida
		</h1>

		<div class="mt-12 mb-8">
			<span class="text-2xl font-bold dark:text-white">Experiencia</span>
		</div>

		<div class="relative">
			<span
				class="absolute top-0 bottom-0 left-3 w-0.5 bg-[linear-gradient(180deg,rgba(16,185,129,0.2),rgba(56,189,248,0.2))] md:left-1/2"
				aria-hidden="true"></span>
			<ol class="relative space-y-8">
				<TimeLineElement
					title="Consultor"
					date="Nov 2025 - actualmente"
					subtitle="TCM Partners, Bogotá, Colombia"
					modality="En remoto"
					side="left"
				>
					<p class="mt-3 text-sm text-neutral-600 dark:text-neutral-300">
						Desarrollo de nuvas funcionalidades para la tesorería de Banco ITAU:
					</p>
					<ul
						class="mt-3 space-y-2 pl-5 text-sm text-neutral-600 dark:text-neutral-300 list-disc"
					>
						<li>SQL Server</li>
						<li>Backend en C#</li>
					</ul>
				</TimeLineElement>

				<TimeLineElement
					title="Desarrollador FullStack"
					date="Feb 2023 - Oct 2025"
					subtitle="Tata Consultancy Services, Bogotá, Colombia"
					modality="En remoto"
					side="right"
				>
					<p class="mt-3 text-sm text-neutral-600 dark:text-neutral-300">
						Desarrollo de aplicativos para Bancolombia:
					</p>
					<ul
						class="mt-3 space-y-2 pl-5 text-sm text-neutral-600 dark:text-neutral-300 list-disc"
					>
						<li>Backend con SpringBoot y Java</li>
						<li>Frontend con NextJS, Angular</li>
						<li>Pruebas unitarias con Mockito y Jest</li>
						<li>Pruebas de aceptación con Cucumber</li>
					</ul>
				</TimeLineElement>

				<TimeLineElement
					title="Desarrollador FullStack"
					date="Mar 2022 - Ene 2023"
					subtitle="Indra, Bogotá, Colombia"
					modality="En remoto"
					side="left"
				>
					<ul
						class="mt-3 space-y-2 pl-5 text-sm text-neutral-600 dark:text-neutral-300 list-disc"
					>
						<li>
							Desarrollo de aplicativo móvil Lending para Tigo Millicom con
							Flutter
						</li>
						<li>Desarrollo de pruebas usando Cucucumber, Serenity</li>
					</ul>
				</TimeLineElement>

				<TimeLineElement
					title="Desarrollador FullStack"
					date="Oct 2021 - Feb 2022"
					subtitle="DB System, Bogotá, Colombia"
					modality="En remoto"
					side="right"
				>
					<ul
						class="mt-3 space-y-2 pl-5 text-sm text-neutral-600 dark:text-neutral-300 list-disc"
					>
						<li>
							Desarrollo de aplicativo web en Angular para universidad de
							Cundinamarca.
						</li>
						<li>Manejo de servidor Tomcat para despliegue de aplicaciones.</li>
						<li>Manejo de base de datos Oracle y PostgreSQL.</li>
					</ul>
				</TimeLineElement>

				<TimeLineElement
					title="Desarrollador FullStack"
					date="Jul 2019 - Sep 2021"
					subtitle="Solredes, Bogotá, Colombia"
					modality="Híbrido"
					side="left"
				>
					<ul
						class="mt-3 space-y-2 pl-5 text-sm text-neutral-600 dark:text-neutral-300 list-disc"
					>
						<li>
							Desarrollo de aplicativos móviles con Flutter para municipio de
							Sopó.
						</li>
						<li>
							Desarrollo de aplicativo móvil en Flutter para seguimiento de
							camiones y gestión de tickets para Transpremier LLC.
						</li>
						<li>
							Desarrollo de suite administrativa creada en Angular y Spring Boot
							para el municipio de Sopó.
						</li>
						<li>
							Manejo de servidores Wildfly para despliegue de aplicativos.
						</li>
						<li>Manejo de base de datos MySQL, Oracle y Postgresql.</li>
						<li>
							Desarrollo de aplicativo web y móvil para manejo de reciclaje con
							React y Flutter.
						</li>
					</ul>
				</TimeLineElement>
			</ol>
		</div>

		<div class="mt-12 mb-8">
			<span class="text-2xl font-bold dark:text-white">Educación</span>
		</div>

		<div class="relative">
			<span
				class="absolute top-0 bottom-0 left-3 w-0.5 bg-[linear-gradient(180deg,rgba(16,185,129,0.2),rgba(56,189,248,0.2))] md:left-1/2"
				aria-hidden="true"></span>
			<ol class="relative space-y-8">
				<TimeLineElement
					title="Ingeniero Telemático"
					date="2022 - 2025"
					subtitle="Universidad Distrital, Bogotá, Colombia"
					side="left"
				/>
				<TimeLineElement
					title="Tecnólogo en Sistematización de Datos"
					date="2015 - 2021"
					subtitle="Universidad Distrital, Bogotá, Colombia"
					side="right"
				/>
			</ol>
		</div>

		<div class="mt-12 mb-8">
			<div class="text-2xl font-bold dark:text-white">
				Conocimentos y aptitudes
			</div>
		</div>

		<ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
			{
				skills.map(({ label, icon: Icon, tone }) => (
					<li class="flex items-center gap-3 rounded-full border border-slate-900/10 bg-white/60 px-3 py-2 text-slate-800 shadow-[0_8px_20px_rgba(15,23,42,0.08)] backdrop-blur-md dark:border-white/10 dark:bg-white/10 dark:text-slate-200">
						<span
							class={`flex h-8 w-8 items-center justify-center rounded-full ${tone}`}
						>
							<Icon class="h-4 w-4" />
						</span>
						<span class="text-sm font-semibold">{label}</span>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>
